# FlashFusion Environment Variables
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local to version control.
#
# See docs/04-configuration.md for full variable documentation.

# ── Required ────────────────────────────────────────────────────────────────
# Supabase project URL (from Supabase Dashboard → Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase public anon key (safe for client-side use)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Application ──────────────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173
VITE_APP_ENV=development

# ── AI Services (optional) ───────────────────────────────────────────────────
# ⚠️  IMPORTANT: These client-side keys are visible in the browser bundle.
# For production AI integrations, use Supabase Edge Function environment
# variables instead, and proxy AI API calls through Edge Functions.
VITE_OPENAI_API_KEY=
VITE_ANTHROPIC_API_KEY=

# ── Analytics (optional) ─────────────────────────────────────────────────────
VITE_SENTRY_DSN=
VITE_MIXPANEL_TOKEN=
VITE_GA_MEASUREMENT_ID=

# ── GitHub Integration (optional) ────────────────────────────────────────────
# GitHub OAuth App client ID (NOT the client secret — that belongs server-side)
VITE_GITHUB_CLIENT_ID=
